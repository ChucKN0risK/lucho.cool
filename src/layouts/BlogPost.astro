---
import { Image } from "astro:assets";
import { type CollectionEntry, render } from "astro:content";
import TOC from "@/components/TOC.astro";
import Layout from "@/layouts/Layout.astro";
import { getFormattedDate, getW3FormattedDate } from "@/utils";
import Clock from "../assets/vectors/clock.svg";

interface Props {
	post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { headings } = await render(post);
const { description, title, coverImage, date, readingTime } = post.data;
const w3FormattedDate = getW3FormattedDate(date);
const formattedDate = getFormattedDate(date);
---

<Layout title={title} description={description} image={coverImage.src}>
  {headings.length > 1 && <TOC headings={headings} />}
  <article class='article-content'>
    <div class='article-hero'>
      <div class='article-img'>
        <Image
          alt=''
          class='object-cover'
          fetchpriority='high'
          loading='eager'
          src={coverImage}
        />
      </div>
      <h1>{title}</h1>
      <div class='article-info'>
        <time datetime={w3FormattedDate}>{formattedDate}</time>
        <div>
          <Clock />
          {readingTime} read
        </div>
      </div>
    </div>
    <slot />
  </article>
</Layout>
